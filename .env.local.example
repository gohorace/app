# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (email delivery)
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=briefing@realestate-insights.app

# Twilio (SMS)
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_FROM_NUMBER=+61400000000

# HOR-56 pair step: hide the SMS-link form when Twilio is unavailable
# (compliance pending, account suspended, etc.). Set to 'true' to show
# the form on the desktop pair screen; any other value hides it. The
# /api/onboarding/sms endpoint stays alive regardless.
NEXT_PUBLIC_PAIRING_SMS_ENABLED=false

# Vercel Cron secret (validates /api/cron/* requests)
CRON_SECRET=a-long-random-secret

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CDN_URL=http://localhost:3000

# Stripe (billing)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_PRO_ANNUAL=price_xxx

# Cal.com (book-a-call help path during onboarding)
NEXT_PUBLIC_CAL_USERNAME=andytwomey
NEXT_PUBLIC_CAL_EVENT_SLUG=15min

# Slack (alert-volume review trigger — HOR-74)
SLACK_ALERT_VOLUME_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
