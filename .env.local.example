# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (email delivery)
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=briefing@realestate-insights.app

# Twilio (SMS)
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_FROM_NUMBER=+61400000000

# HOR-56 pair step: hide the SMS-link form when Twilio is unavailable
# (compliance pending, account suspended, etc.). Set to 'true' to show
# the form on the desktop pair screen; any other value hides it. The
# /api/onboarding/sms endpoint stays alive regardless.
NEXT_PUBLIC_PAIRING_SMS_ENABLED=false

# Vercel Cron secret (validates /api/cron/* requests)
CRON_SECRET=a-long-random-secret

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CDN_URL=http://localhost:3000

# Stripe (billing)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_PRO_ANNUAL=price_xxx
# HOR-203 Support seats — $39/mo AUD inc. GST. Annual mirrors the 17% pro
# discount. Operator creates both prices in Stripe; webhook handler is
# agnostic to which price ids these point at.
STRIPE_PRICE_SUPPORT_SEAT_MONTHLY=price_xxx
STRIPE_PRICE_SUPPORT_SEAT_ANNUAL=price_xxx
# Gate the support-seats UI behind this flag. When false, /settings/team
# falls back to the pre-HOR-203 invite dropdown (Agent / Manager only).
NEXT_PUBLIC_SUPPORT_SEATS_ENABLED=true

# HOR-204 Custom domains for Doorstep — Vercel Domains API.
# VERCEL_API_TOKEN: scope to the project or team. Server-side only.
# VERCEL_PROJECT_ID: the gohorace.com production project.
# VERCEL_TEAM_ID: required when the project sits under a team.
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

# Cal.com (book-a-call help path during onboarding)
NEXT_PUBLIC_CAL_USERNAME=andytwomey
NEXT_PUBLIC_CAL_EVENT_SLUG=15min

# Slack (alert-volume review trigger — HOR-74)
SLACK_ALERT_VOLUME_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# HOR-106 / HOR-224 — Gmail OAuth (tracked email send, slice B).
# Create an OAuth 2.0 Client (Web application) in Google Cloud Console.
# Authorized redirect URI must include:
#   https://gohorace.com/api/integrations/gmail/callback
#   plus each Vercel preview URL (https://<preview>.vercel.app/api/integrations/gmail/callback)
# Scope requested at runtime: gmail.send + openid + email + profile.
# Verification status is tracked in HOR-105 (Google review can take 4–6 weeks;
# until then the consent screen shows an "unverified app" interstitial and
# caps usage at 100 test users).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://gohorace.com/api/integrations/gmail/callback

# Optional: separate signing secret for the OAuth state cookie.
# Falls back to SUPABASE_SERVICE_ROLE_KEY when unset (same pattern as UNSUB_SECRET).
OAUTH_STATE_SECRET=

# HOR-106 / HOR-225 — Email tracking pixel + click HMAC secret (slice C).
# Used to sign tokens on /t/o/[token] (open pixel) and /t/c/[token] (click).
# Falls back to SUPABASE_SERVICE_ROLE_KEY when unset. Rotating this invalidates
# every in-flight tracked send — that's the intended kill-switch behaviour.
# Tokens are versioned (v1.<idHex>.<urlIdx>.<sig16>) so a future rotation can
# run two secrets simultaneously by bumping to v2.
EMAIL_TRACKING_SECRET=
